  <property name="styleSheet">
   <string notr="true">/* ====== GLOBAL ====== */
QMainWindow {
    background-color: #eef7f2;
    font-size: 18pt;
    font-family: &quot;Segoe UI&quot;, &quot;Roboto&quot;, sans-serif;
    color: #1f2d2a;
}

/* ====== MENU BAR ====== */
QMenuBar {
    background-color: #2e7d5a;
    color: #ffffff;
    padding: 6px;
    spacing: 10px;
    border: none;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 14px;
    border-radius: 6px;
}

QMenuBar::item:selected {
    background-color: #3fa37a;
}

QMenuBar::item:pressed {
    background-color: #2a8c68;
}

/* ====== MENUS ====== */
QMenu {
    background-color: #ffffff;
    border: 1px solid #cde8dc;
    border-radius: 8px;
    padding: 6px;
}

QMenu::item {
    padding: 10px 20px;
    border-radius: 6px;
    background-color: transparent;
}

QMenu::item:selected {
    background-color: #d4f5e9;
    color: #1f2d2a;
}

QMenu::item:disabled {
    color: #9bb8ae;
}

/* ====== ACTIONS (indirect styling via menu items) ====== */
QMenu::separator {
    height: 1px;
    background: #cde8dc;
    margin: 6px 10px;
}

/* ====== OPTIONAL: TOOLTIP ====== */
QToolTip {
    background-color: #2e7d5a;
    color: #ffffff;
    border: none;
    padding: 6px;
    border-radius: 6px;
    font-size: 16pt;
}</string>
