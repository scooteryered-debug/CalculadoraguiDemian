   <string notr="true">/* Fondo general del diálogo */
QDialog {
    background-color: #121212;
    color: #E0E0E0;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 10pt;
}

/* Etiquetas */
QLabel {
    color: #CCCCCC;
    font-weight: 500;
}

QLabe#label_resultado {
    color: #CCCCCC;
	font-size:48pt;
    font-weight: 500;
}

/* Campos de texto */
QLineEdit {
    background-color: #1E1E1E;
    border: 1px solid #333333;
    border-radius: 6px;
    padding: 6px 8px;
    color: #FFFFFF;
    selection-background-color: #B71C1C;
}

QLineEdit:focus {
    border: 1px solid #E53935;
    background-color: #232323;
}

/* Botones */
QPushButton {
    background-color: #B71C1C;
    border: none;
    border-radius: 6px;
    padding: 8px 14px;
    color: white;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #E53935;
}

QPushButton:pressed {
    background-color: #7F0000;
}

/* Botón secundario (opcional con objectName) */
QPushButton#secondaryButton {
    background-color: transparent;
    border: 1px solid #555;
    color: #CCC;
}

QPushButton#secondaryButton:hover {
    border: 1px solid #E53935;
    color: #FFF;
}</string>
